---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import type { App } from '../../data/apps';

interface Props {
  apps: App[];
}

const { apps } = Astro.props;
---

<div class="apps">
  {apps.map((app) => (
    <div class="app">
      <h2>{app.name}</h2>
      <p>{app.copy}</p>
      <a href={app.url}>
        <div>{app.img ? <Image src={app.img} alt={`Open the app ${app.name}`} class="manual"/> : <Icon name="carbon:cics-program" title="open app" size="100px" />}</div>
      </a>
    </div>
  )) }
</div>

<style>
.apps {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6px;
}
.app {
  width: 300px;
  border: 1px solid var(--color-grey);
  border-radius: 6px;
  padding: 6px;
  position: relative;
}
.app img {
  width: 100px;
  height: 100px;
  object-fit: contain;
  display: block;
}
.app a {
  display: block;
}
.app a::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
</style>
